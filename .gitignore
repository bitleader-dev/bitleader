# 글로벌 gitignore 의 `.github/` 제외를 본 저장소 한정으로 해제
# (GitHub Actions 워크플로우가 반드시 커밋되어야 배포가 동작함)
!.github/
!.github/**

# 빌드 결과물
dist/
.astro/

# 의존성
node_modules/

# 환경 변수 (개인 토큰 포함 - 절대 커밋 금지)
.env
.env.local
.env.*.local

# 개인/내부 문서 (커밋 제외)
plan.md
notes.md
CLAUDE.md

# 로컬 테스트용 mock fixture (MOCK_REPOS=1 로 사용, 커밋 제외)
src/test-fixtures/

# 로그
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS 파일
.DS_Store
Thumbs.db

# 에디터/IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# 빌드 캐시
.cache/

# Playwright E2E 결과물 (커밋 제외)
test-results/
playwright-report/
blob-report/
.playwright/

# Lighthouse 분석용 임시 폴더 (gh run download 결과물, 커밋 제외)
.lighthouse-tmp/
