---
// 오른쪽 Releases 카드
// 참고 디자인:
// - 최신 1개: 태그 + Latest 배지 + 본문 (details 로 접어 Markdown 풀 렌더) + Release notes 링크
// - 과거 2개: 태그 + 날짜 (간략)
// - "+ N releases" 링크 (3개 초과 시)
// - 0개: "No releases yet" 플레이스홀더
//
// 릴리스 본문 Markdown 렌더링: renderMarkdown(shiki + sanitize-html) 으로 빌드 타임 변환
// 사이드바 폭이 좁아 펼치기 전에는 토글 한 줄만 노출 (details/summary)

import type { GitHubRelease } from '../../lib/types';
import { formatRelative } from '../../i18n/dictionary';
import { renderMarkdown } from '../../lib/readme';

interface Props {
  releases: GitHubRelease[];
  repoUrl: string;
  repoName: string;
  defaultBranch: string;
}

const { releases, repoUrl, repoName, defaultBranch } = Astro.props;

// 최신 릴리스 1개, 그 다음 2개, 나머지 개수
const latest = releases[0];
const past = releases.slice(1, 3);
const remaining = releases.length > 3 ? releases.length - 3 : 0;

// 최신 릴리스 본문을 안전한 HTML 로 미리 변환 (빌드 타임)
// 본문이 비면 null 로 두어 details 자체를 렌더하지 않음
const latestBodyHtml =
  latest?.body && latest.body.trim().length > 0
    ? await renderMarkdown(latest.body, repoName, defaultBranch)
    : null;

// 빌드 타임에는 한국어로 렌더. 클라이언트에서 i18n.ts 가 data-iso 를 읽어 선택 언어로 재포맷.
const fmtKo = (iso: string | null): string => (iso ? formatRelative(iso, 'ko') : '');

const releasesIndexUrl = `${repoUrl}/releases`;
---

<div class="glass-card rounded-xl overflow-hidden">
  <div class="px-6 py-4 border-b border-white/10 flex justify-between items-center">
    <h3 class="font-headline-md text-white text-lg" data-i18n="releases_heading">릴리스</h3>
    <span class="px-2 py-1 rounded-md bg-white/5 text-white/40 text-[10px]">{releases.length}</span>
  </div>

  {
    releases.length === 0 ? (
      <div class="p-6 text-center">
        <p class="text-sm text-white/40" data-i18n="releases_none">등록된 릴리스가 없습니다</p>
      </div>
    ) : (
      <div class="p-6 space-y-6">
        {/* Latest release */}
        {latest && (
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="text-primary-container font-bold">{latest.tag_name}</span>
                <span class="bg-on-tertiary-container/20 text-tertiary-container px-2 py-0.5 rounded text-[10px] font-black" data-i18n="releases_latest_badge">
                  최신
                </span>
              </div>
              <span class="text-xs text-white/40" data-iso={latest.published_at ?? latest.created_at}>{fmtKo(latest.published_at ?? latest.created_at)}</span>
            </div>
            {latestBodyHtml && (
              <details class="group">
                <summary class="text-[11px] text-white/60 cursor-pointer hover:text-[#00F0FF] inline-flex items-center gap-1 list-none">
                  <span class="material-symbols-outlined text-[14px] transition-transform group-open:rotate-90">chevron_right</span>
                  <span data-i18n="releases_body_toggle">릴리스 본문 보기</span>
                </summary>
                <div class="mt-3 prose-dark text-sm" set:html={latestBodyHtml} />
              </details>
            )}
            <a
              class="flex items-center gap-1 text-[11px] text-[#00F0FF] hover:underline"
              href={latest.html_url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="material-symbols-outlined text-[14px]">description</span>
              <span data-i18n="releases_notes_link">릴리스 노트</span>
            </a>
          </div>
        )}

        {/* 과거 릴리스 2개 */}
        {past.length > 0 && (
          <div class="space-y-4 pt-2">
            {past.map((r) => (
              <a
                class="flex items-center justify-between text-sm hover:text-[#00F0FF] transition-colors"
                href={r.html_url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="flex items-center gap-2 text-white/80">
                  <span class="material-symbols-outlined text-white/40 text-[18px]">sell</span>
                  <span>{r.tag_name}</span>
                </div>
                <span class="text-xs text-white/40" data-iso={r.published_at ?? r.created_at}>{fmtKo(r.published_at ?? r.created_at)}</span>
              </a>
            ))}
          </div>
        )}

        {/* "+ N releases" 링크 */}
        {remaining > 0 && (
          <a
            class="block w-full text-center py-2 text-xs text-white/40 hover:text-[#00F0FF] border border-white/5 rounded transition-all"
            href={releasesIndexUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-i18n-tpl="releases_more"
            data-i18n-var-remaining={remaining}
          >
            + {remaining}개 릴리스 더 보기
          </a>
        )}
      </div>
    )
  }
</div>
