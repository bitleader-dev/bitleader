---
// 상단 고정 내비게이션 바
// 참고: stitch_dark_card_dashboard/code.html 동일 구조 (로고만 BIT LEADER로 교체)
// - 좌측: 로고 + 검색 입력 (참고 디자인 유지)
// - 우측: 언어 선택 드롭다운
import LanguageSwitch from './LanguageSwitch.astro';
---

<header
  class="fixed top-0 right-0 left-0 h-16 border-b border-white/10 z-40 bg-zinc-950/50 backdrop-blur-md w-full"
>
  <div class="h-full max-w-[1440px] mx-auto flex items-center justify-between px-8">
    <div class="flex items-center gap-6 flex-1">
      <h1 class="text-xl font-black tracking-tighter text-cyan-400 mr-4">BIT LEADER</h1>
      <div class="relative w-full max-w-md group">
        <span
          class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-sm group-focus-within:text-cyan-400 transition-colors"
          >search</span
        >
        <input
          id="search-input"
          class="w-full bg-surface-container-lowest/50 border-none rounded-full py-2 pl-10 pr-4 text-sm text-zinc-300 focus:ring-1 focus:ring-cyan-500/50 placeholder-zinc-600 transition-all"
          placeholder="저장소 검색..."
          data-i18n-attr="placeholder:search_placeholder"
          type="text"
          autocomplete="off"
        />
      </div>
    </div>
    <div class="flex items-center gap-5">
      <LanguageSwitch />
    </div>
  </div>
</header>
