---
// 저장소 카드 1개
// 참고: code.html의 project card 구조
// - 이미지 영역은 항상 h-48 유지
// - README에 이미지가 없거나 로딩 실패 시 public/Thumbnail.png 기본 이미지로 폴백
// 카드 전체가 저장소 URL로 이동하는 링크 역할
// 클라이언트 필터링용 data-* 속성 임베드

import type { RepoCardData } from '../lib/types';
import { withBase } from '../lib/paths';

interface Props {
  card: RepoCardData;
}

const { card } = Astro.props;

// 본문에 표시할 설명: description 우선, 없으면 README 요약
const bodyText = card.description?.trim() || card.summary || '';

// chip 2개: 언어 + 첫 번째 topic (없으면 생략)
const chips: string[] = [];
if (card.language) chips.push(card.language);
if (card.topics.length > 0) chips.push(card.topics[0]);

// 필터/정렬용 데이터 속성
const topicsAttr = card.topics.join(',');

const detailHref = withBase(`/${card.name}`);

// 이미지 폴백 처리: README 이미지 없을 때 / 원격 이미지 로딩 실패 시 모두 기본 이미지로 대체
const fallbackImage = withBase('/Thumbnail.png');
const cardImage = card.imageUrl ?? fallbackImage;
const onImageError = `this.onerror=null;this.src='${fallbackImage}';`;
---

<a
  href={detailHref}
  class="repo-card md:col-span-4 glass-panel rounded-xl overflow-hidden group hover:micro-border hover:neon-glow transition-all flex flex-col h-full"
  data-name={card.name.toLowerCase()}
  data-description={(card.description ?? '').toLowerCase()}
  data-topics={topicsAttr}
  data-stars={card.stars}
  data-updated={card.updatedAt}
  data-created={card.createdAt}
  data-archived={card.archived ? '1' : '0'}
  data-fork={card.fork ? '1' : '0'}
>
  <div class="relative h-48 overflow-hidden flex-shrink-0">
    <img
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      src={cardImage}
      alt={card.name}
      loading="lazy"
      onerror={onImageError}
    />
    <!-- 북마크 버튼 (상단 좌측) — 클릭 시 링크 이동 차단하고 localStorage 토글 -->
    <button
      type="button"
      class="bookmark-btn absolute top-2 left-2 z-10 w-7 h-7 rounded-full bg-zinc-900/80 border border-white/10 backdrop-blur-sm flex items-center justify-center text-zinc-500 hover:text-[#00F0FF] transition-colors"
      data-repo-name={card.name}
      aria-pressed="false"
      aria-label="북마크 추가"
      data-i18n-arialabel="bookmark_add"
    >
      <span class="material-symbols-outlined text-[18px]">star</span>
    </button>
    {
      (card.archived || card.fork) && (
        <div class="absolute top-2 right-2 flex gap-1.5">
          {card.archived && (
            <span
              class="text-[10px] px-2 py-0.5 rounded bg-zinc-900/80 border border-amber-400/40 text-amber-300 backdrop-blur-sm uppercase tracking-wider font-medium"
              data-i18n="badge_archived"
            >
              보관됨
            </span>
          )}
          {card.fork && (
            <span
              class="text-[10px] px-2 py-0.5 rounded bg-zinc-900/80 border border-white/20 text-zinc-300 backdrop-blur-sm uppercase tracking-wider font-medium"
              data-i18n="badge_fork"
            >
              포크
            </span>
          )}
        </div>
      )
    }
  </div>
  <div class="p-6 flex flex-col flex-1">
    <h4 class="font-headline-md text-base text-white">{card.name}</h4>
    {
      bodyText && (
        <p class="text-zinc-400 text-sm mt-2 line-clamp-2">{bodyText}</p>
      )
    }
    {
      chips.length > 0 && (
        <div class="mt-4 flex gap-2 flex-wrap">
          {chips.map((c) => (
            <span class="text-[10px] border border-white/10 px-2 py-0.5 rounded text-zinc-500 uppercase">
              {c}
            </span>
          ))}
        </div>
      )
    }
    <!-- 업데이트 날짜: mt-auto 로 카드 바닥에 고정 → 같은 행의 모든 카드가 동일 baseline 에 정렬 -->
    <!-- data-iso 로 i18n.ts 가 언어 전환 시 formatRelative 로 자동 갱신 -->
    <div class="mt-auto pt-3 text-[11px] text-zinc-500">
      <span data-i18n="card_updated_label">업데이트</span>:
      <span data-iso={card.updatedAt}>{card.updatedAt.slice(0, 10)}</span>
    </div>
  </div>
</a>
