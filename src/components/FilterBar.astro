---
// Topic 필터 (다중 선택, AND 조합) + 정렬 드롭다운
// - Topic 필터: 커스텀 드롭다운 (버튼 + 체크박스 목록 패널)
//   - 여러 topic 을 동시에 선택하면 "모든 topic 을 가진" 카드만 남음 (AND)
//   - 선택 개수는 버튼에 표시 (0개 = "전체 Topic", 1개 이상 = "N개 선택됨")
// - 정렬 드롭다운: 기존 `<select>` 유지
// 클라이언트 필터링 로직은 src/scripts/filter.ts 에서 처리

interface Props {
  topics: string[];
  languages: string[];
}

const { topics, languages } = Astro.props;
---

<div class="flex flex-wrap items-center gap-6 mb-6">
  <div class="relative min-w-[180px] flex items-center gap-3">
    <label
      for="language-filter"
      class="text-zinc-500 font-label-md uppercase tracking-wider whitespace-nowrap"
      data-i18n="label_language"
    >
      Language
    </label>
    <div class="relative flex-1 group">
      <select
        id="language-filter"
        class="w-full appearance-none bg-surface-container-low border border-white/10 rounded px-4 py-2 text-sm text-white focus:outline-none focus:border-primary-container/50 focus:ring-1 focus:ring-primary-container/20 transition-all cursor-pointer"
      >
        <option class="bg-zinc-900" value="" data-i18n="language_all">전체 언어</option>
        {languages.map((lang) => (
          <option class="bg-zinc-900" value={lang}>{lang}</option>
        ))}
      </select>
      <span
        class="material-symbols-outlined absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 pointer-events-none group-focus-within:text-primary-container"
      >
        expand_more
      </span>
    </div>
  </div>

  <!-- Topic 다중 필터 -->
  <div class="relative min-w-[200px] flex items-center gap-3">
    <label
      for="topic-filter-toggle"
      class="text-zinc-500 font-label-md uppercase tracking-wider whitespace-nowrap"
      data-i18n="label_topic"
    >
      Topic
    </label>
    <div class="relative flex-1" id="topic-filter">
      <button
        id="topic-filter-toggle"
        type="button"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls="topic-filter-panel"
        class="w-full flex items-center justify-between bg-surface-container-low border border-white/10 rounded px-4 py-2 text-sm text-white focus:outline-none focus:border-primary-container/50 focus:ring-1 focus:ring-primary-container/20 transition-all cursor-pointer"
      >
        <span id="topic-filter-label" data-i18n="topic_multi_placeholder">전체 Topic</span>
        <span class="material-symbols-outlined text-zinc-500">expand_more</span>
      </button>
      {topics.length > 0 && (
        <div
          id="topic-filter-panel"
          role="listbox"
          aria-multiselectable="true"
          class="hidden absolute top-full left-0 right-0 mt-1 max-h-64 overflow-y-auto bg-zinc-900 border border-white/10 rounded shadow-lg z-20"
        >
          <ul class="py-1">
            {topics.map((t) => (
              <li>
                <label class="flex items-center gap-2 px-3 py-2 text-sm text-zinc-300 hover:bg-white/5 cursor-pointer">
                  <input
                    type="checkbox"
                    class="topic-checkbox accent-[#00F0FF] w-3.5 h-3.5"
                    value={t}
                  />
                  <span>{t}</span>
                </label>
              </li>
            ))}
          </ul>
          <div class="border-t border-white/10 px-3 py-2 flex justify-end">
            <button
              id="topic-filter-clear"
              type="button"
              class="text-[11px] text-zinc-400 hover:text-[#00F0FF] transition-colors"
              data-i18n="topic_clear"
            >
              초기화
            </button>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- 정렬 드롭다운 -->
  <div class="relative min-w-[200px] flex items-center gap-3">
    <label
      for="sort-order"
      class="text-zinc-500 font-label-md uppercase tracking-wider whitespace-nowrap"
      data-i18n="label_sort"
    >
      정렬
    </label>
    <div class="relative flex-1 group">
      <select
        id="sort-order"
        class="w-full appearance-none bg-surface-container-low border border-white/10 rounded px-4 py-2 text-sm text-white focus:outline-none focus:border-primary-container/50 focus:ring-1 focus:ring-primary-container/20 transition-all cursor-pointer"
      >
        <option class="bg-zinc-900" value="updated" data-i18n="sort_updated">최근 업데이트순</option>
        <option class="bg-zinc-900" value="stars" data-i18n="sort_stars">스타 많은순</option>
        <option class="bg-zinc-900" value="name" data-i18n="sort_name">이름순 (A-Z)</option>
        <option class="bg-zinc-900" value="created" data-i18n="sort_created">최근 생성순</option>
      </select>
      <span
        class="material-symbols-outlined absolute right-2 top-1/2 -translate-y-1/2 text-zinc-500 pointer-events-none group-focus-within:text-primary-container"
      >
        expand_more
      </span>
    </div>
  </div>

  <!-- 결과 카운트 (클라이언트에서 업데이트) -->
  <span id="result-count" class="text-xs text-zinc-500 ml-auto"></span>
</div>
