---
// 공통 레이아웃: 폰트 로드 + 전역 스타일 + 메타 태그 + 전역 Footer
// - Open Graph / Twitter 카드 포함 (슬랙·카카오톡 등 공유 미리보기용)
// - favicon은 public/favicon.svg
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import { absoluteUrl, withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  /** 상세 페이지 등에서 저장소별 동적 OG 이미지 경로를 주입할 때 사용. base path 를 제외한 "/og/foo.png" 형태로 전달. */
  ogImagePath?: string;
  /** Schema.org JSON-LD 구조화 데이터 (단일 객체 또는 객체 배열). 검색엔진 리치 스니펫용. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'BIT LEADER',
  description = 'BIT LEADER 엔지니어링 팀이 만든 제품과 실험을 공유하는 공간입니다.',
  ogImagePath,
  jsonLd,
} = Astro.props;

// og:url / canonical 은 "현재 페이지" 기준 절대 URL 로 주입해야 공유 미리보기 클릭 시 올바른 페이지로 이동함
// ogImagePath 가 주어지면 저장소별 동적 OG 이미지, 없으면 전역 Thumbnail.png 폴백
const absoluteOgImage = absoluteUrl(Astro.site, ogImagePath ?? '/Thumbnail.png');
const faviconHref = withBase('/favicon.svg');
const rssHref = withBase('/rss.xml');

// 현재 페이지 절대 URL — trailing slash 를 항상 붙여 sitemap 과 일관성 유지 (정적 /index.html 경로 기준)
const rawPathname = Astro.url.pathname;
const normalizedPathname = rawPathname.endsWith('/') ? rawPathname : `${rawPathname}/`;
const canonicalUrl = Astro.site
  ? new URL(normalizedPathname, Astro.site).toString()
  : Astro.url.toString();
---

<!DOCTYPE html>
<html class="dark" lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- 다크 톤 일관성: Android Chrome 주소창/상태바 색상 + 브라우저 chrome(스크롤바·기본 폼 컨트롤) 다크 매칭 -->
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="color-scheme" content="dark" />

    <!-- 언어 사전 세팅 (플래시 최소화): localStorage > navigator.language > 'ko' -->
    <!-- STORAGE_KEY='lang' 는 src/i18n/dictionary.ts 와 동일해야 함 (inline 이라 번들 공유 불가) -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('lang');
          if (stored === 'ko' || stored === 'en') {
            document.documentElement.lang = stored;
            return;
          }
        } catch (e) {
          /* noop */
        }
        var nav = (navigator.language || 'ko').toLowerCase();
        document.documentElement.lang = nav.indexOf('en') === 0 ? 'en' : 'ko';
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="BIT LEADER, bitleader-dev, GitHub, 대시보드, 오픈소스, 릴리스, Astro"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={faviconHref} />

    <!-- Canonical URL (SEO / 소셜 공유 일관성) -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- RSS 자동 발견 — 브라우저/리더기가 /rss.xml 을 자동 인식하게 함 -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="BIT LEADER — Releases"
      href={rssHref}
    />

    <!-- Open Graph (공유 미리보기) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BIT LEADER" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />

    <!-- X(구 Twitter) Card — X 는 리브랜딩 후에도 동일한 twitter:* 메타 태그 규격을 계속 사용 -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- 폰트 로드: 영문은 Inter, 한글은 Noto Sans KR (Inter에 한글 글리프 없으므로 자동 fallback) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- LCP 카드 이미지 host: 첫 카드 README 이미지가 raw.githubusercontent.com 에서 로드됨 → connection setup 단축 -->
    <link rel="preconnect" href="https://raw.githubusercontent.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Noto+Sans+KR:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Material Symbols Outlined (아이콘) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    {/* Schema.org JSON-LD: 검색엔진 리치 스니펫용 구조화 데이터 (선택적 주입) */}
    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>
  <body
    class="bg-background text-on-background font-body-md antialiased selection:bg-primary-container selection:text-on-primary-container"
  >
    <!-- 스킵 링크: 키보드 Tab 첫 포커스 시 노출되어 본문 랜드마크(#main) 로 건너뛰게 한다 -->
    <a
      href="#main"
      class="fixed left-4 top-4 z-[100] -translate-y-[200%] focus-visible:translate-y-0 bg-[#00F0FF] text-[#0A0A0A] px-4 py-2 text-sm font-semibold rounded transition-transform"
      data-i18n="a11y_skip_to_main"
    >
      본문 바로가기
    </a>

    <slot />
    <Footer />

    <!-- 전역 토스트 — 북마크 후 카드가 다른 페이지로 이동했을 때 등 일시적 안내 -->
    <!-- 기본은 숨김(pointer-events-none + opacity-0), filter.ts 가 표시/숨김 클래스 토글 -->
    <div
      id="global-toast"
      role="status"
      aria-live="polite"
      class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[90] pointer-events-none opacity-0 translate-y-2 bg-[#00F0FF] text-[#0A0A0A] text-sm font-semibold px-4 py-2 rounded shadow-lg transition-all"
    ></div>

    <!-- 클라이언트 사이드 언어 전환 런타임 (전역) -->
    <script>
      import '../scripts/i18n.ts';
    </script>
  </body>
</html>
