---
// 메인 대시보드 페이지
// 빌드 타임에 GitHub에서 public 저장소 + README를 페칭하여 카드 렌더링
// 참고 디자인: stitch_dark_card_dashboard/code.html

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import DashboardHero from '../components/DashboardHero.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getAllRepoCards, collectTopics } from '../lib/data';

// 빌드 타임 데이터 페칭
const cards = await getAllRepoCards();
const topics = collectTopics(cards);
---

<Layout>
  <Header />

  <main class="pt-24 px-8 pb-12 min-h-screen max-w-[1440px] mx-auto">
    <DashboardHero />
    <FilterBar topics={topics} />

    {
      cards.length === 0 ? (
        <div class="glass-panel rounded-xl p-12 text-center">
          <p class="text-zinc-400">
            표시할 저장소가 없습니다. GitHub API 호출에 실패했거나 public 저장소가 없을 수 있습니다.
          </p>
        </div>
      ) : (
        <div id="card-grid" class="grid grid-cols-1 md:grid-cols-12 gap-6">
          {cards.map((card) => <ProjectCard card={card} />)}
        </div>
      )
    }
  </main>

  <!-- 클라이언트 필터/정렬 스크립트 -->
  <script>
    import '../scripts/filter.ts';
  </script>
</Layout>
