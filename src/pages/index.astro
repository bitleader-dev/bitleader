---
// 메인 대시보드 페이지
// 빌드 타임에 GitHub에서 public 저장소 + README를 페칭하여 카드 렌더링
// 참고 디자인: stitch_dark_card_dashboard/code.html

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import DashboardHero from '../components/DashboardHero.astro';
import FilterBar from '../components/FilterBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import RecentReleases from '../components/RecentReleases.astro';
import { getAllRepoCards, collectTopics, collectLanguages, collectRecentReleases } from '../lib/data';
import { absoluteUrl } from '../lib/paths';

// 빌드 타임 데이터 페칭
const cards = await getAllRepoCards();
const topics = collectTopics(cards);
const languages = collectLanguages(cards);
const recentReleases = await collectRecentReleases(3);

const siteUrl = absoluteUrl(Astro.site, '/');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: 'BIT LEADER',
      description:
        'BIT LEADER 엔지니어링 팀이 만든 제품과 실험을 공유하는 공간입니다.',
      inLanguage: 'ko',
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#organization`,
      name: 'BITLEADER CORP.',
      url: siteUrl,
      sameAs: ['https://github.com/bitleader-dev'],
    },
  ],
};
---

<Layout jsonLd={jsonLd}>
  <Header />

  <main id="main" class="pt-24 px-8 pb-12 min-h-screen max-w-[1440px] mx-auto">
    <DashboardHero />
    <RecentReleases items={recentReleases} />
    <FilterBar topics={topics} languages={languages} />

    {
      cards.length === 0 ? (
        <div class="glass-panel rounded-xl p-12 text-center">
          <p class="text-zinc-400">
            표시할 저장소가 없습니다. GitHub API 호출에 실패했거나 public 저장소가 없을 수 있습니다.
          </p>
        </div>
      ) : (
        <div id="card-grid" class="grid grid-cols-1 md:grid-cols-12 gap-6">
          {cards.map((card) => <ProjectCard card={card} />)}
        </div>
        <!-- 검색/필터 결과 0건 안내 -->
        <div
          id="empty-state"
          class="hidden glass-panel rounded-xl p-12 text-center"
          role="status"
          aria-live="polite"
        >
          <p class="text-zinc-200 text-lg" data-i18n="empty_state_title">검색 결과가 없습니다</p>
          <p class="mt-2 text-zinc-400 text-sm" data-i18n="empty_state_hint">다른 검색어 또는 필터를 시도해 보세요</p>
          <button
            id="reset-filters"
            type="button"
            class="mt-6 px-4 py-2 rounded border border-[#00F0FF]/40 text-sm text-[#00F0FF] hover:bg-[#00F0FF]/10 transition-all"
            data-i18n="empty_state_reset"
          >필터 초기화</button>
        </div>
        <!-- 페이지네이션 (저장소 12개 초과 시에만 filter.ts 가 노출) -->
        <nav
          id="pagination"
          class="hidden mt-8 flex items-center justify-center gap-4"
          aria-label="페이지 네비게이션"
        >
          <button
            id="page-prev"
            type="button"
            class="px-3 py-1.5 rounded border border-white/10 text-sm text-zinc-300 hover:text-[#00F0FF] hover:border-[#00F0FF]/40 disabled:opacity-40 disabled:cursor-not-allowed transition-all"
            data-i18n="pagination_prev"
            aria-label="이전 페이지"
            data-i18n-arialabel="pagination_prev_aria"
          >이전</button>
          <span id="page-info" class="text-sm text-zinc-400" aria-live="polite"></span>
          <button
            id="page-next"
            type="button"
            class="px-3 py-1.5 rounded border border-white/10 text-sm text-zinc-300 hover:text-[#00F0FF] hover:border-[#00F0FF]/40 disabled:opacity-40 disabled:cursor-not-allowed transition-all"
            data-i18n="pagination_next"
            aria-label="다음 페이지"
            data-i18n-arialabel="pagination_next_aria"
          >다음</button>
        </nav>
      )
    }
  </main>

  <!-- 클라이언트 필터/정렬 스크립트 -->
  <script>
    import '../scripts/filter.ts';
  </script>
</Layout>
