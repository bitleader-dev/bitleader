---
// 저장소 상세 페이지 (동적 라우트)
// URL: /bitleader/{repo-name}
// 참고: stitch_dark_card_dashboard (1)/code.html 동일 레이아웃

import Layout from '../layouts/Layout.astro';
import DetailHeader from '../components/detail/DetailHeader.astro';
import ReadmePanel from '../components/detail/ReadmePanel.astro';
import ReleasesCard from '../components/detail/ReleasesCard.astro';
import ActionButtons from '../components/detail/ActionButtons.astro';
import { getDetailRouteList, getRepoDetail } from '../lib/data';

// 빌드 타임에 모든 저장소 상세 페이지 경로 생성
export async function getStaticPaths() {
  const list = await getDetailRouteList();
  // 각 저장소마다 RepoDetailData를 미리 조회해 props로 전달 (중복 API 호출 방지)
  const entries = await Promise.all(
    list.map(async (item) => {
      const detail = await getRepoDetail(item.name);
      return detail ? { params: { repo: item.name }, props: { detail } } : null;
    })
  );
  return entries.filter((e): e is NonNullable<typeof e> => e !== null);
}

const { detail } = Astro.props;
const pageTitle = `${detail.name} — BIT LEADER`;
// 저장소별 동적 OG 이미지 경로 (빌드 타임에 /og/<repo>.png 로 생성됨)
const ogImagePath = `/og/${detail.name}.png`;
---

<Layout title={pageTitle} description={detail.description ?? undefined} ogImagePath={ogImagePath}>
  <DetailHeader />

  <main id="main" class="pt-16 min-h-screen">
    <div class="max-w-[1440px] mx-auto px-8 py-12">
      <!-- 저장소 이름 + About description (있을 때만) -->
      <div class="mb-8">
        <div class="flex items-center gap-2 text-white/40 font-label-md">
          <span class="text-[#00F0FF] font-bold">{detail.name}</span>
        </div>
        {detail.description && (
          <p class="mt-2 text-zinc-400 text-base max-w-[800px]">{detail.description}</p>
        )}
      </div>

      <div class="grid grid-cols-12 gap-8">
        <!-- 왼쪽: README 패널 -->
        <div class="col-span-12 lg:col-span-8">
          <ReadmePanel html={detail.readmeHtml} />
        </div>

        <!-- 오른쪽: Releases 카드 + 액션 버튼 -->
        <div class="col-span-12 lg:col-span-4 space-y-6">
          <ReleasesCard
            releases={detail.releases}
            repoUrl={detail.url}
            repoName={detail.name}
            defaultBranch={detail.defaultBranch}
          />
          <ActionButtons downloadUrl={detail.downloadUrl} repoUrl={detail.url} />
        </div>
      </div>
    </div>
  </main>

  <!-- Back to Top: 300px 이상 스크롤 시 우하단 표시, 클릭 시 상단으로 smooth scroll -->
  <button
    id="back-to-top"
    type="button"
    class="fixed right-6 bottom-6 z-40 w-11 h-11 rounded-full bg-zinc-900/80 border border-white/10 backdrop-blur-sm text-white/60 hover:text-[#00F0FF] hover:border-[#00F0FF]/40 flex items-center justify-center shadow-lg opacity-0 pointer-events-none translate-y-2 transition-all"
    aria-label="맨 위로"
    data-i18n-arialabel="back_to_top"
  >
    <span class="material-symbols-outlined text-[20px]">keyboard_arrow_up</span>
  </button>

  <script is:inline>
    (function () {
      var btn = document.getElementById('back-to-top');
      if (!btn) return;
      var update = function () {
        if (window.scrollY > 300) {
          btn.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
        } else {
          btn.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
        }
      };
      window.addEventListener('scroll', update, { passive: true });
      btn.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      update();
    })();
  </script>
</Layout>
