---
// 404 Not Found 페이지
// - 존재하지 않는 경로 접근 시 GitHub Pages 가 자동으로 이 페이지를 반환
// - 디자인은 상세 페이지 스타일을 재사용하여 일관성 유지
// - Lumina Dark 톤 + 큰 404 숫자 + 설명 + 홈으로 버튼

import Layout from '../layouts/Layout.astro';
import DetailHeader from '../components/detail/DetailHeader.astro';
import { withBase } from '../lib/paths';

const homeHref = withBase('/');
const pageTitle = '404 — BIT LEADER';
const pageDescription = '요청하신 페이지를 찾을 수 없습니다.';
---

<Layout title={pageTitle} description={pageDescription}>
  <DetailHeader />

  <main id="main" class="pt-16 min-h-screen">
    <div class="max-w-[1440px] mx-auto px-8 py-24 flex flex-col items-center justify-center text-center">
      <div
        class="text-[120px] sm:text-[180px] leading-none font-black text-[#00F0FF] neon-glow tracking-tighter"
        aria-hidden="true"
      >
        404
      </div>

      <h1 class="mt-8 text-2xl sm:text-3xl font-bold text-white" data-i18n="notfound_title">
        페이지를 찾을 수 없습니다
      </h1>

      <p class="mt-4 text-base text-zinc-400 max-w-lg" data-i18n="notfound_desc">
        요청하신 저장소 페이지가 존재하지 않거나, 이름이 변경되었을 수 있습니다.
      </p>

      <a
        href={homeHref}
        class="mt-10 inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#00F0FF]/10 border border-[#00F0FF]/30 text-[#00F0FF] hover:bg-[#00F0FF]/20 hover:border-[#00F0FF]/60 transition-all"
      >
        <span class="material-symbols-outlined text-[20px]">home</span>
        <span class="text-sm font-medium" data-i18n="btn_home">홈으로</span>
      </a>
    </div>
  </main>
</Layout>
