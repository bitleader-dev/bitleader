# GitHub Personal Access Token (로컬 개발용)
# Fine-grained PAT 발급 시 public_repo 읽기 권한만 부여
# 발급: https://github.com/settings/tokens?type=beta
# 본 파일(.env.example)은 커밋 가능, 실제 토큰이 든 .env는 .gitignore에 의해 커밋 차단됨
GITHUB_TOKEN=

# 로컬 테스트용 mock 모드 (페이지네이션/필터/검색/OG 등 UX 검증용 fake 저장소)
# 1 설정 시 실제 GitHub API 대신 src/test-fixtures/mock-repos.ts 의 fake 데이터 사용
# fixture 파일은 .gitignore 로 커밋 제외됨 — 없으면 실제 API 로 자동 폴백
# MOCK_REPOS=1
